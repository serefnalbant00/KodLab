<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Kodlab v2.0 - Simülatör</title>
    <style>
        /* SİTENİN TASARIMI (CSS) */
        body { background-color: #0f172a; color: white; font-family: sans-serif; display: flex; flex-direction: column; align-items: center; padding: 20px; }
        .container { width: 90%; max-width: 800px; background: #1e293b; padding: 20px; border-radius: 12px; box-shadow: 0 10px 30px rgba(0,0,0,0.5); }
        h1 { color: #38bdf8; margin-bottom: 10px; }
        textarea { width: 100%; height: 150px; background: #0f172a; color: #34d399; border: 1px solid #334155; border-radius: 8px; padding: 10px; font-family: monospace; resize: none; margin-bottom: 10px; }
        button { background: #22c55e; color: white; border: none; padding: 12px 25px; border-radius: 8px; cursor: pointer; font-weight: bold; width: 100%; transition: 0.3s; }
        button:hover { background: #16a34a; }
        #terminal { background: black; color: #4da6ff; padding: 15px; border-radius: 8px; margin-top: 15px; font-family: monospace; height: 120px; overflow-y: auto; border-left: 4px solid #38bdf8; font-size: 13px; }
        iframe { width: 100%; height: 200px; background: white; border: none; border-radius: 8px; margin-top: 15px; }
        .error { color: #ff4d4d; }
    </style>
</head>
<body>

    <div class="container">
        <h1>Hoş Geldin, Geliştirici</h1>
        <p>Kodlab v2.0 ile kodlarını simüle et.</p>
        
        <!-- KOD YAZMA ALANI -->
        <textarea id="kod-input" placeholder="HTML veya CSS kodlarını buraya yapıştır..."></textarea>
        
        <button onclick="tamDenetimliCalistir()">Simülasyonu Başlat</button>

        <!-- KODLARIN DÖNDÜĞÜ TERMİNAL -->
        <div id="terminal">> Sistem hazır. Kod girişi bekleniyor...</div>

        <!-- GERÇEK ÇIKTI EKRANI -->
        <iframe id="onizleme-frame"></iframe>
    </div>

    <script>
        /* AKILLI ÇALIŞTIRMA MOTORU (JavaScript) */
        
        // 1. HAFIZA: Sayfa yenilenince kodları geri getir
        window.onload = () => {
            const kayıtlı = localStorage.getItem("kodlab_v2_save");
            if (kayıtlı) document.getElementById("kod-input").value = kayıtlı;
        };

        function tamDenetimliCalistir() {
            const editor = document.getElementById("kod-input"); 
            const terminal = document.getElementById("terminal");
            const onizleme = document.getElementById("onizleme-frame");
            const kod = editor.value.trim();

            // Kaydet
            localStorage.setItem("kodlab_v2_save", kod);

            // 2. KONTROL: "Aa" veya boş metinleri engelle
            const regex = /<[a-z][\s\S]*>|{.*}/i; 
            
            if (!regex.test(kod) || kod.length < 4) {
                terminal.innerHTML = `<div class="error">[HATA]: Geçersiz kod yapısı!<br>> Simülasyon iptal edildi.</div>`;
                return; 
            }

            // 3. EFEKT: Kodların dönme simülasyonu
            terminal.innerHTML = "<b>> Analiz başlatıldı...</b>";
            let islemler = [
                "> Sözdizimi ağacı oluşturuluyor...",
                "> Etiketler doğrulanıyor...",
                "> CSS kuralları derleniyor...",
                "> BAŞARILI: Kod simüle edildi!"
            ];

            let i = 0;
            let interval = setInterval(() => {
                if (i < islemler.length) {
                    terminal.innerHTML += `<div>${islemler[i]}</div>`;
                    terminal.scrollTop = terminal.scrollHeight;
                    i++;
                } else {
                    clearInterval(interval);
                    
                    // 4. GERÇEK ÇALIŞTIRMA
                    const doc = onizleme.contentWindow.document;
                    doc.open();
                    doc.write(kod); 
                    doc.close();
                }
            }, 250); 
        }
    </script>

</body>
</html>

